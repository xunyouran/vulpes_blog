---
import TagBadge from './TagBadge.astro';
import { formatDate } from '../utils/date';

export interface Props {
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  readingTime?: string;
}

const { pubDate, updatedDate, tags = [], readingTime } = Astro.props;
---

<div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[var(--color-text-tertiary)]">
  <!-- Publication date -->
  <time datetime={pubDate.toISOString()}>
    <svg class="inline-block h-4 w-4 mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    {formatDate(pubDate)}
  </time>

  <!-- Updated date (if different from pub date) -->
  {
    updatedDate && updatedDate.getTime() !== pubDate.getTime() && (
      <span>
        <span class="mx-1">·</span>
        更新于 {formatDate(updatedDate)}
      </span>
    )
  }

  <!-- Reading time -->
  {readingTime && (
    <>
      <span class="hidden sm:inline">·</span>
      <span>阅读 {readingTime}</span>
    </>
  )}

  <!-- Tags -->
  {
    tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 w-full sm:w-auto">
        <span class="hidden sm:inline text-[var(--color-text-tertiary)]">·</span>
        {tags.map((tag) => <TagBadge tag={tag} size="sm" />)}
      </div>
    )
  }
</div>
