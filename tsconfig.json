{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@utils/*": ["src/utils/*"],
      "@assets/*": ["src/assets/*"]
    },
    "jsx": "preserve",
    "jsxImportSource": "astro"
  },
  "include": ["src/**/*.ts", "src/**/*.astro"],
  "exclude": ["dist", "node_modules"]
}
